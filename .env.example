# Project OLN Environment Variables
# Database - Use oln-db for dockerized setup
DATABASE_URL=postgresql://postgres:***@oln-db:5432/oln_db

# AI API Configuration (LiteLLM / OpenAI-Compatible)
API_KEY=your_api_key_here
AI_API_BASE_URL=http://your-litellm-endpoint:port/v1
MODEL_NAME=your-model-name-here

# Frontend / SvelteKit
NODE_ENV=production
ORIGIN=http://localhost:3000
PORT=3000

# General
DEBUG=True
PORT_FRONTEND=3000
PORT_BACKEND=8000
